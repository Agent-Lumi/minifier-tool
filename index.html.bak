<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Minify JavaScript, CSS, and HTML code for production">
    <meta name="author" content="Agent-Lumi">
    <title>Minifier Tool | Made by Agent-Lumi</title>
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🗜️</text></svg>">
</head>
<body>
    <div class="container">
        <header>
            <div class="logo"><span>🗜️</span></div>
            <h1>Minifier Tool</h1>
            <p>Minify JavaScript, CSS, and HTML for production</p>
        </header>
        <main>
            <div class="tool-box">
                <div class="mode-selector">
                    <button class="mode-btn active" data-mode="js" onclick="setMode('js')">JavaScript</button>
                    <button class="mode-btn" data-mode="css" onclick="setMode('css')">CSS</button>
                    <button class="mode-btn" data-mode="html" onclick="setMode('html')">HTML</button>
                </div>
                
                <!-- File Upload Section -->
                <div class="upload-section" id="dropZone">
                    <div class="upload-content">
                        <div class="upload-icon">📁</div>
                        <p class="upload-text">Drag & drop your file here</p>
                        <p class="upload-hint">or click to browse</p>
                        <p class="upload-types">Supports: .js, .css, .html</p>
                    </div>
                    <input type="file" id="fileInput" accept=".js,.css,.html" hidden>
                </div>
                
                <div class="editor-container">
                    <div class="input-section">
                        <label>Input Code:</label>
                        <textarea id="input" placeholder="Paste your code here..." rows="10"></textarea>
                    </div>
                    
                    <div class="actions">
                        <button onclick="minify()" class="primary">🗜️ Minify</button>
                        <button onclick="copyOutput()" class="secondary">📋 Copy Result</button>
                        <button onclick="downloadMinified()" class="secondary">💾 Download</button>
                        <button onclick="clearAll()" class="secondary">🗑️ Clear</button>
                    </div>
                    
                    <div class="output-section">
                        <label>Minified Output:</label>
                        <textarea id="output" readonly placeholder="Minified code will appear here..." rows="10"></textarea>
                    </div>
                    
                    <div id="stats" class="stats"></div>
                </div>
            </div>
        </main>
        <footer>
            <p>Made with 💡 by <a href="https://github.com/Agent-Lumi" target="_blank">Agent-Lumi</a> for <a href="https://github.com/shalkith" target="_blank">@shalkith</a></p>
            <p><a href="https://github.com/Agent-Lumi/minifier-tool" target="_blank">View on GitHub →</a></p>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>
<script>
// Usage stats
const stats = JSON.parse(localStorage.getItem('app-stats') || '{}');
stats.visits = (stats.visits || 0) + 1;
stats.lastVisit = new Date().toISOString();
localStorage.setItem('app-stats', JSON.stringify(stats));
console.log('Visits:', stats.visits);
</script>
